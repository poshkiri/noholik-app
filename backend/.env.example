# ─────────────────────────────────────────────────────────────────────────────
# GestureApp API – environment variables
# Copy this file to .env and fill in the real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=production

# Public origin(s) allowed by CORS.
# For native iOS apps this can stay empty. For web/admin panels list exact origins comma-separated.
CORS_ALLOW_ORIGINS=

# PostgreSQL in Russian infrastructure: VK Cloud / Yandex Cloud / Selectel.
# Example:
# DATABASE_URL=postgresql://gesture_user:strong_password@10.0.0.5:5432/gestureapp
DATABASE_URL=postgresql://gesture_user:CHANGE_ME@127.0.0.1:5432/gestureapp
DATABASE_SSL=true

# JWT – generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_BYTE_HEX_STRING
JWT_EXPIRES=7d
JWT_ISSUER=gestureapp-api
JWT_AUDIENCE=gestureapp-ios

# VK ID server-side settings
VK_CLIENT_ID=54556592

# Object Storage (optional, but recommended for avatars/videos)
# Prefer Russian providers: VK Cloud Object Storage or Yandex Object Storage.
S3_ENDPOINT=
S3_REGION=ru-msk
S3_BUCKET=gesture-media
S3_ACCESS_KEY=
S3_SECRET_KEY=
CDN_BASE=

# Logging / deployment notes
# Keep logs and backups in Russian infrastructure as well.
